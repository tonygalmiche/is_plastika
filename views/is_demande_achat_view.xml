            <field name="name">is_plastika_demande_achat_fg_form_view</field>
            <field name="model">is.demande.achat.fg</field>
            <field name="inherit_id" ref="is_plastigray16.is_demande_achat_fg_form_view"/>
            <field name="arch" type="xml">
                <field name="fournisseur_id" position="after">
                    <field name="is_societe_comptable" readonly="1"/>
