<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="is_mrp_production_tree_view_inherit" model="ir.ui.view">
            <field name="name">is_mrp_production_tree_view_inherit</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="is_plastigray16.is_mrp_production_tree_view"/>
            <field name="arch" type="xml">
                <field name="product_id" position="after">
                    <field name="is_societe_comptable"/>
                </field>
            </field>
        </record>
        <record id="is_mrp_production_form_view_inherit" model="ir.ui.view">
            <field name="name">is_mrp_production_form_view_inherit</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="is_plastigray16.is_mrp_production_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet/group/group/field[@name='product_id']" position="after">
                    <field name="is_societe_comptable"/>
                </xpath>
            </field>
        </record>
        <record id="is_view_mrp_production_filter_inherit" model="ir.ui.view">
            <field name="name">is_view_mrp_production_filter_inherit</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="is_plastigray16.is_view_mrp_production_filter"/>
            <field name="arch" type="xml">
                <field name="product_id" position="after">
                    <field name="is_societe_comptable"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
